#!/usr/bin/env php
<?php

use Al3x5\xBot\Devkit\Generator;
use Al3x5\xBot\Devkit\Generator\Entities;
use Al3x5\xBot\Devkit\Generator\Methods;
use Al3x5\xBot\Devkit\Scrapper;

include getcwd() . '/vendor/autoload.php';

echo "🌐 Start scraping\n";
echo "This process may take a few seconds...\n";
$data = Scrapper::data();

echo "🏗️​  Creating entities\n";
Entities::generate($data['types']);

echo "💻 Obtaining methods\n";
Methods::generate($data['methods']);

echo "✅ Update to {$data['version']}\n";
